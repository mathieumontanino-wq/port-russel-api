<!DOCTYPE html>
<html>

<head>
<title>Utilisateurs</title>
<link rel="stylesheet" href="/style.css">
</head>

<body>

<%- include("partials/sidebar") %>

<div class="main-content">

<div class="container">

<h1>Liste des Utilisateurs</h1>

<table class="table">

<thead>

<tr>
<th>Username</th>
<th>Email</th>
</tr>

</thead>

<tbody>

<% users.forEach(user => { %>

<tr>

<td><%= user.username %></td>
<td><%= user.email %></td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</div>

</body>
</html>